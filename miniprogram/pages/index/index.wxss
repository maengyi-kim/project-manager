/** 首页样式 */
.page {
  padding-bottom: 20px;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 20px 16px;
  color: #fff;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 28px;
  font-weight: bold;
}

.active-num {
  color: #4caf50;
}

.overdue-num {
  color: #f44336;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.7);
  margin-top: 4px;
}

/* 创建按钮 */
.create-bar {
  padding: 12px 16px;
}

.create-btn {
  width: 100%;
}

/* 项目卡片 */
.project-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin: 10px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.project-card:active {
  opacity: 0.7;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.project-name {
  font-size: 17px;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  margin-right: 8px;
}

.project-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.meta-item {
  font-size: 12px;
  color: #888;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 10px;
}

.progress-section .progress-bar {
  flex: 1;
}

.progress-text {
  font-size: 13px;
  color: #666;
  min-width: 40px;
  text-align: right;
}

.project-desc {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 8px;
  line-height: 1.5;
}
