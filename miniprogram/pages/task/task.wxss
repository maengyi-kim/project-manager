/** 任务编辑页样式 */
.page { padding-bottom: 40px; }

.form-group { margin-bottom: 16px; }
.label { display: block; font-size: 13px; color: #888; margin-bottom: 6px; font-weight: 500; }
.input {
  width: 100%;
  padding: 14px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  min-height: 48px;
}

.form-row { display: flex; gap: 12px; }
.half { flex: 1; }

.picker {
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
}

/* 优先级 */
.priority-group { display: flex; gap: 8px; }
.priority-btn {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  font-size: 12px;
}
.priority-btn.active { color: #fff; border-color: transparent; }
.priority-btn.p0 { border-color: #f44336; color: #c62828; }
.priority-btn.p0.active { background: #f44336; color: #fff; }
.priority-btn.p1 { border-color: #ff9800; color: #e65100; }
.priority-btn.p1.active { background: #ff9800; color: #fff; }
.priority-btn.p2 { border-color: #2196f3; color: #1565c0; }
.priority-btn.p2.active { background: #2196f3; color: #fff; }
.priority-btn.p3 { border-color: #9e9e9e; color: #616161; }
.priority-btn.p3.active { background: #9e9e9e; color: #fff; }

/* 快速进度 */
.quick-progress { display: flex; gap: 8px; margin-top: 8px; }
.qp-btn {
  flex: 1;
  text-align: center;
  padding: 6px 0;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  font-size: 12px;
  color: #666;
}
.qp-btn.active { background: #e8f5e9; border-color: #66bb6a; color: #2e7d32; }

/* 文本框 */
.textarea {
  width: 100%;
  min-height: 80px;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

/* 子任务 */
.children-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.add-subtask-btn {
  font-size: 12px;
  color: #1a1a2e;
  font-weight: 500;
  padding: 4px 10px;
  border: 1px dashed #1a1a2e;
  border-radius: 6px;
}
.add-subtask-btn:active {
  background: #f0f0ff;
}
.children-list {
  border: 1px solid #f0f0f0;
  border-radius: 8px;
  overflow: hidden;
}
.child-task {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  border-bottom: 1px solid #f5f5f5;
  background: #fafafa;
}
.child-task:last-child { border-bottom: none; }
.child-task:active { background: #f0f0f0; }
.child-left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}
.child-check {
  width: 18px;
  height: 18px;
  border: 2px solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #4caf50;
  flex-shrink: 0;
}
.child-check.done { border-color: #4caf50; background: #e8f5e9; }
.child-title { font-size: 13px; color: #333; flex: 1; }
.child-title.done { text-decoration: line-through; color: #999; }
.child-right {
  display: flex;
  align-items: center;
  gap: 6px;
}
.child-progress { font-size: 12px; color: #888; }
.child-arrow { font-size: 16px; color: #ccc; }
.empty-children {
  text-align: center;
  padding: 16px;
  font-size: 13px;
  color: #bbb;
  border: 1px dashed #eee;
  border-radius: 8px;
}

/* 操作按钮 */
.action-row { margin: 20px 16px; text-align: center; }
.save-btn { width: 100%; margin-bottom: 12px; }
