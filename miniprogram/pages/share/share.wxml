<!-- 只看模式 -->
<view class="page">
  <view class="header-banner">
    <text class="banner-title">{{project.name || '项目进度'}}</text>
    <text class="banner-sub">只读模式 · 仅查看</text>
  </view>

  <view class="card">
    <view class="progress-row">
      <view class="progress-bar big">
        <view class="progress-fill {{project.overdue_count > 0 ? 'overdue' : ''}}" style="width: {{project.progress}}%"></view>
      </view>
      <text class="progress-text-big">{{project.progress}}%</text>
    </view>
    <view class="meta-row">
      <text>任务: {{project.task_count || 0}}</text>
      <text wx:if="{{project.overdue_count > 0}}" style="color:#c62828;">逾期: {{project.overdue_count}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">任务列表</view>
    <view wx:for="{{tasks}}" wx:key="id" class="share-task" style="padding-left: {{taskDepth(item) * 20 + 12}}px;">
      <view class="share-task-inner">
        <text class="share-check {{item.status === 'completed' ? 'done' : ''}}">{{item.status === 'completed' ? '✓' : '○'}}</text>
        <view class="share-content">
          <text class="share-title {{item.status === 'completed' ? 'done' : ''}}">{{item.title}}</text>
          <text class="share-assignee" wx:if="{{item.assignee}}">{{item.assignee}}</text>
        </view>
        <text class="share-progress">{{item.progress}}%</text>
      </view>
    </view>
  </view>
</view>
