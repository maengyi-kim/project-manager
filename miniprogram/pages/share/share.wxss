/** 只看模式样式 */
.header-banner {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 30px 20px;
  text-align: center;
  color: #fff;
}
.banner-title { font-size: 22px; font-weight: 700; }
.banner-sub { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 4px; }

.progress-row { display: flex; align-items: center; gap: 12px; }
.progress-bar.big { height: 10px; flex: 1; }
.progress-text-big { font-size: 24px; font-weight: bold; color: #1a1a2e; min-width: 50px; }
.meta-row { display: flex; gap: 12px; font-size: 13px; color: #888; margin-top: 10px; }

.section-title { font-size: 16px; font-weight: 600; margin-bottom: 12px; }

.share-task { margin-bottom: 6px; }
.share-task-inner {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
}
.share-check {
  width: 22px; text-align: center; font-size: 16px; color: #ccc; margin-right: 10px;
}
.share-check.done { color: #4caf50; }
.share-content { flex: 1; }
.share-title { font-size: 14px; color: #333; display: block; }
.share-title.done { text-decoration: line-through; color: #999; }
.share-assignee { font-size: 11px; color: #999; }
.share-progress { font-size: 13px; color: #666; min-width: 36px; text-align: right; }
