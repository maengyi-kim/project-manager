/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f6fa;
  color: #333;
}

/* 卡片容器 */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin: 10px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 14px;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-small {
  padding: 6px 14px;
  font-size: 12px;
  border-radius: 6px;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  margin-right: 4px;
}

.tag-active {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-completed {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-overdue {
  background: #ffebee;
  color: #c62828;
}

.tag-paused {
  background: #fff3e0;
  color: #e65100;
}

/* 进度条容器 */
.progress-bar {
  height: 6px;
  background: #e0e0e0;
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4caf50, #81c784);
  border-radius: 3px;
  transition: width 0.3s;
}

.progress-fill.overdue {
  background: linear-gradient(90deg, #f44336, #ef9a9a);
}

/* 状态图标 */
.status-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.status-dot.active {
  background: #4caf50;
}

.status-dot.paused {
  background: #ff9800;
}

.status-dot.completed {
  background: #2196f3;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #999;
}

.empty-state text {
  font-size: 14px;
}
